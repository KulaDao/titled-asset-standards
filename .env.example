# Deployer EOA private key (never commit the real value)
PRIVATE_KEY=0x

# Admin address for registry contracts (can be a multisig)
ADMIN_ADDRESS=0x

# Alchemy Sepolia RPC — https://eth-sepolia.g.alchemy.com/v2/<your-key>
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Optional: secondary demo wallet granted ATTESTOR_ROLE post-deploy, used to
# show the self-attestation-blocked flow in eip-5 ImpactSnapshotLog
# (generate with `cast wallet new`; never commit the real private key)
DEMO_ATTESTOR_ADDRESS=0x
DEMO_ATTESTOR_PRIVATE_KEY=0x
