# Deployer EOA private key (never commit the real value)
PRIVATE_KEY=0x

# Admin address for registry contracts (can be a multisig)
ADMIN_ADDRESS=0x

# Alchemy Sepolia RPC — https://eth-sepolia.g.alchemy.com/v2/<your-key>
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=
